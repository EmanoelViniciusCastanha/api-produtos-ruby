# Arquivos que NÃO devem ir para o Git (gerados/temporários/sensíveis).

# Bancos SQLite (recriados com db:migrate + db:seed)
/db/*.sqlite3
/db/*.sqlite3-*

# Logs
/log/*
!/log/.keep

# Arquivos temporários e cache
/tmp/*
!/tmp/.keep
!/tmp/pids/
/tmp/pids/*
!/tmp/pids/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Uploads do Active Storage
/storage/*
!/storage/.keep

# Segredos / credenciais
/config/master.key
/config/credentials/*.key
.kamal/secrets
.env*

# Dependências instaladas localmente
/.bundle
/vendor/bundle

# Sistema operacional
.DS_Store
Thumbs.db
